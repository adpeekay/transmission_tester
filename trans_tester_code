#include <Wire.h>
#include <BH1750.h>
#include <LiquidCrystal.h>
#include <LiquidCrystal_I2C.h>

//setup 16x2 LCD - create 2 icons to use on the LCD
LiquidCrystal_I2C lcd(0x27, 16, 2);
byte smiley[8] = {
  0b00000,
  0b00000,
  0b01010,
  0b00000,
  0b00000,
  0b10001,
  0b01110,
  0b00000
};

byte frownie[8] = {
  0b00000,
  0b00000,
  0b01010,
  0b00000,
  0b00000,
  0b00000,
  0b01110,
  0b10001
};

//setup lightmeters
BH1750 lightmeter_a;
BH1750 lightmeter_b;

const int numReadings = 10;
const int buttonPin = 6;

int readings[numReadings];
int readings2[numReadings];
int readIndex = 0;
int readIndex2 = 0;
int total = 0;
int total2 = 0;
float average = 0;
float average2 = 0;
float diff = 0;
float diff1 = 0;
float diff2 = 0;
float lux_a = 0; 
float lux_b = 0; 
int Round;
int i = 0;
long start;
long end;

//setup system
void setup() {
  Serial.begin(9600);
  Wire.begin();
  pinMode(buttonPin, INPUT_PULLUP);
  lightmeter_a.begin(BH1750::CONTINUOUS_HIGH_RES_MODE, 0x23); //address should 0x23
  lightmeter_b.begin(BH1750::CONTINUOUS_HIGH_RES_MODE, 0x5C); //hardware note - connect vcc to add
  lcd.createChar(0, smiley);
  lcd.createChar(1, frownie);
  lcd.begin(16, 2);
  lcd.clear();
  lcd.backlight();
  lcd.setCursor(0, 0);
  lcd.print("Trans tester...");
  Serial.println("transmission tester setting up...");
  delay(1000);
  lcd.setCursor(0, 1);
  lcd.print("Ready!");
  Serial.println("Ready!");
  //this section sets up 2 arrays and makes sure they are 'empty'
  for (int thisReading = 0; thisReading < numReadings; thisReading++) {
    readings[thisReading] = 0;
  }
  for (int thisReading2 = 0; thisReading2 < numReadings; thisReading2++) {
    readings[thisReading2] = 0;
  }
  delay(1000);
  lcd.clear();
  lcd.setCursor(0, 0);
  lcd.print("press button");
  lcd.setCursor(0, 1);
  lcd.print("to measure");
}

//setup a reset function to be called anytime
void(* resetFunc)(void) = 0;

//setup trans_measure function
void trans_measure() {
  for (int thisReading = 0; thisReading < numReadings; thisReading++)
  {
    lcd.clear();
    lcd.setCursor(0, 0);
    lcd.print("sampling");
    lcd.setCursor(0, 1);
    lcd.print("hold still");
    // subtract the last reading:
    total = total - readings[readIndex];
    total2 = total2 - readings2[readIndex2];
    // read from the sensor:
    readings[readIndex] = lightmeter_a.readLightLevel();
    readings2[readIndex2] = lightmeter_b.readLightLevel();
    //Serial.print(readings[readIndex]);
    //Serial.print(", ");
    //Serial.println(readings2[readIndex2]);
    // add the reading to the total:
    total = total + readings[readIndex];
    total2 = total2 + readings2[readIndex2];
    // advance to the next position in the array:
    readIndex = readIndex + 1;
    readIndex2 = readIndex2 + 1;

    // calculate the average:
    average = total / numReadings;
    average2 = total2 / numReadings;
    delay(500);
  }//end of for loop
  lcd.clear();
  lcd.setCursor(0, 0);
  lcd.print("Calculating.......");
  delay(1000);
  diff = average2 / average;
  diff1 = diff * 100;
  Serial.print(diff1);
  Serial.println(" % transmission");
  diff1 = diff1 / 10;
  Round = int(round(diff1));
  Round = Round * 10;
  Serial.print(Round);
  Serial.println(" % transmission to nearest 10");
  delay(1000);
  lcd.clear();
  lcd.setCursor(0, 0);
  lcd.print(Round);
  lcd.setCursor(3, 0);
  lcd.print("% transmission");
  lcd.setCursor(0, 1);
  lcd.print("press to reset");
  start = millis();
  lcd.setCursor(15,1);
  lcd.write(smiley);
    
  do {
    end = millis() - start;
      if (digitalRead(buttonPin) == LOW) {
      resetFunc();
      }
  } while (end < 20000);
     
  resetFunc();
} // end of void

//setup dual measure function
void dual_measure() {
  i=0;
  lux_a = lightmeter_a.readLightLevel();
  lux_b = lightmeter_b.readLightLevel();
  Serial.print("a: ");
  Serial.print(lux_a);
  Serial.println(" lux");
  Serial.print("b: ");
  Serial.print(lux_b);
  Serial.println(" lux");
  Serial.println(i);
  delay(1000);
  i++;
  //loop();
} //end of void

//setup standard loop - clear LCD and prepare to measure
void loop() {
  
  if (digitalRead(buttonPin) == HIGH) {
    dual_measure();
  }
  else {
    trans_measure();
  }

}    
